{
  "name": "bookcraft",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --turbopack -H 0.0.0.0 -p 5000",
    "build": "next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "build:mobile": "next build && npx cap sync",
    "start": "next start -H 0.0.0.0 -p 5000",
    "lint": "eslint",
    "test:openai": "node scripts/test-openai.js",
    "generate:icons": "node scripts/generate-icons.js",
    "cap:init": "npx cap init",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:prepare": "mkdir -p out android/app/src/main/assets/public ios/App/App/public && echo '<!DOCTYPE html><html><head><title>Bookcraft</title></head><body></body></html>' > out/index.html",
    "cap:sync": "npm run cap:prepare && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
